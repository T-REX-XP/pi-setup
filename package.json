{
  "name": "pi-setup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for pi infrastructure, workflows, agents, secrets, and fleet management.",
  "keywords": [
    "pi-package",
    "pi",
    "automation",
    "fleet",
    "cloudflare"
  ],
  "scripts": {
    "install:hooks": "bash scripts/install-hooks.sh",
    "bump": "node scripts/bump-version.mjs",
    "daemon": "node scripts/fleet-daemon.mjs",
    "fleetctl": "node scripts/fleetctl.mjs",
    "secrets:sync": "node scripts/secrets-sync.mjs",
    "enrollment:issue": "node scripts/enrollment-token-issue.mjs",
    "machine:enroll": "node scripts/machine-enroll.mjs",
    "validate": "node scripts/validate-setup.mjs"
  },
  "dependencies": {
    "playwright": "^1.53.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      ".pi/extensions"
    ],
    "prompts": [
      ".pi/prompts"
    ],
    "skills": [
      ".pi/skills"
    ]
  }
}
