{
  "name": "pi-setup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for pi infrastructure, workflows, agents, secrets, and fleet management.",
  "keywords": [
    "pi-package",
    "pi",
    "automation",
    "fleet",
    "cloudflare"
  ],
  "scripts": {
    "init": "node scripts/pi-init.mjs",
    "install:hooks": "bash scripts/install-hooks.sh",
    "bump": "node scripts/bump-version.mjs",
    "daemon": "node scripts/fleet-daemon.mjs",
    "fleetctl": "node scripts/fleetctl.mjs",
    "secrets:sync": "node scripts/secrets-sync.mjs",
    "enroll": "node scripts/pi-enroll.mjs",
    "trace:websocket": "node scripts/websocket-event-trace.mjs",
    "observability:report": "node scripts/observability-report.mjs",
    "validate": "node scripts/validate-setup.mjs",
    "e2e": "node scripts/browser-e2e.mjs"
  },
  "dependencies": {
    "playwright": "^1.53.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.2",
    "@sinclair/typebox": "*"
  },
  "pi": {
    "extensions": [
      ".pi/extensions"
    ],
    "prompts": [
      ".pi/prompts"
    ],
    "skills": [
      ".pi/skills"
    ]
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
